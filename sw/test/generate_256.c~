#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <time.h>

int main(void) {
  srand(time(NULL));

  printf("vars = 256;\n\n");

  printf("vector = [");
  for (int i = 0; i < 256; ++i) {
    int16_t x = (rand() % 65536) - 32768;
    printf("%d", x);
    if (i != 255) printf(",\n");
  }
  printf("];\n\n");

  printf("matrix = [");
  for (int i = 0; i < 256 * 256; ++i) {
    int16_t x = (rand() % 65536) - 32768;
    printf("%d", x);
    if (i != 256 * 256 - 1) {
      printf(",\n");
    }
    
  }
  printf("];\n");

  return 0;
}
